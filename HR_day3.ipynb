      "(1, 4) (1, 5) (1, 6) (2, 4) (2, 5) (2, 6) (3, 4) (3, 5) (3, 6) "
     ]
    }
   ],
   "source": [
    "a = map(int, input().split())\n",
    "b = map(int, input().split())\n",
    "c = product(a,b)\n",
    "for _ in c:\n",
    "    print(_,end=' ')"
   ]
